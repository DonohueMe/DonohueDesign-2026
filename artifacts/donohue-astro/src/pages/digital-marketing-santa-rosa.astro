---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { p } from '../utils/path';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Digital Marketing Santa Rosa",
  "description": "Local SEO, AI-powered outreach, and email marketing automation for Santa Rosa businesses.",
  "provider": {
    "@type": "ProfessionalService",
    "name": "Donohue Design",
    "url": "https://donahuedesign.com",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Santa Rosa",
      "addressRegion": "CA",
      "addressCountry": "US"
    }
  },
  "areaServed": "Santa Rosa, CA",
  "serviceType": "Digital Marketing"
};

const timelineSteps = [
  { label: 'Purpose & Goals',          body: 'Lead generation, e-commerce, brand awareness \u2014 with measurable KPIs tied to business objectives.' },
  { label: 'Target Audience',          body: 'User personas, journey mapping, pain points, and how real customers behave.' },
  { label: 'Content Strategy',         body: 'What to create, how to organize it, tone of voice, and messaging hierarchy.' },
  { label: 'Information Architecture', body: 'Site structure, navigation, and page hierarchy so users find what they need.' },
  { label: 'Technical Strategy',       body: 'Platform, hosting, performance, security, accessibility, and mobile-friendliness.' },
  { label: 'SEO & Discoverability',    body: 'Keyword targeting, on-page optimization, and visibility in search and AI-powered results.' },
  { label: 'Conversion Optimization',  body: 'CTAs, landing pages, and funnel design that turn visitors into customers.' },
  { label: 'Measurement & Iteration',  body: 'Analytics, A/B testing, and ongoing performance review cycles.' },
];

const sidebarCards = [
  {
    title: 'Website Design',
    description: 'Strategy-first websites built to generate leads, earn trust, and turn visitors into customers.',
    items: ['Website Design & Strategy', 'Smart Websites', 'Website Development'],
    icon: '<rect x="3" y="6" width="22" height="14" rx="1.5"/><path d="M3 20h22"/><path d="M11 24h6M14 20v4"/><rect x="22" y="14" width="8" height="14" rx="1.5"/><path d="M25.5 26.5h1"/>',
    vb: '0 0 34 34',
  },
  {
    title: 'Digital Marketing',
    description: 'AI-powered campaigns, local SEO, and automated outreach \u2014 running around the clock to grow your business.',
    items: ['Local SEO (Google My Business)', 'AI Receptionist', 'Email Marketing Automation'],
    icon: '<path d="M4 26 L13 17 L18 22 L29 9"/><path d="M22 9 H29 V16"/><path d="M4 29 H30"/>',
    vb: '0 0 34 34',
  },
  {
    title: 'Graphic Design',
    description: 'Logos, brand systems, and marketing materials that make your business look like the professional operation it already is.',
    items: ['Presentation Design', 'Email Design', 'Brochure & Flyer Design', 'Logo Design'],
    icon: '<path d="M17 4a13 13 0 1 0 0 26c1.7 0 2.8-1.1 2.8-2.5 0-.65-.25-1.25-.7-1.7-.45-.45-.7-1.05-.7-1.7 0-1.4 1.1-2.5 2.5-2.5h2.6A5 5 0 0 0 28.5 16 13 13 0 0 0 17 4z"/><circle cx="10.5" cy="14" r="1.4"/><circle cx="15" cy="9" r="1.4"/><circle cx="21" cy="10" r="1.4"/><circle cx="24.5" cy="15" r="1.4"/>',
    vb: '0 0 34 34',
  },
];

const sections = [
  {
    id: 'intro',
    heading: 'Digital Marketing Santa Rosa',
    body: [
      'Most small businesses in Santa Rosa leave customers on the table \u2014 not because their service is bad, but because nobody can find them online.',
      'I build digital marketing systems that fix that. From optimizing your Google Business Profile and climbing local search rankings to automated email campaigns and AI-powered follow-up, everything I build is designed to bring in business consistently, not just occasionally.',
    ],
  },
  {
    id: 'seo',
    heading: 'Local SEO & Google My Business',
    body: [
      'For local businesses, Google is the front door. I optimize your Google Business Profile, build local citations, and structure your website so Google understands exactly who you serve and where.',
      'The result: your business shows up when Santa Rosa residents search for the services you offer \u2014 not your competitors three towns away.',
    ],
  },
  {
    id: 'ai',
    heading: 'AI Receptionist',
    body: [
      'Never miss a lead again. An AI receptionist answers questions, books appointments, and qualifies leads around the clock \u2014 on your website, via text, or through your business line.',
      'It works while you sleep, while you\u2019re with a client, and over every holiday weekend. Your competitors who rely on voicemail are losing leads to you.',
    ],
  },
  {
    id: 'email',
    heading: 'Email Marketing Automation',
    body: [
      'Your email list is the one channel you own outright \u2014 no algorithm can take it away. I build automated sequences that nurture leads, re-engage past customers, and drive repeat business on autopilot.',
      'From welcome sequences and post-project follow-ups to seasonal campaigns and referral programs, every email is mapped to a specific business outcome.',
    ],
  },
];
---

<BaseLayout
  title="Digital Marketing Santa Rosa | Donohue Design"
  description="Local SEO, AI-powered outreach, and email marketing automation for Santa Rosa and Sonoma County businesses. Strategy-first digital marketing by Jim Donohue."
  schema={schema}
>

  <Hero variant="marketing" />

  <!-- ═══ BODY: editorial + sidebar ═══ -->
  <div class="editorial-wrap">

    <main style="flex:1 1 0;min-width:0;">

      {sections.map((sec, si) => (
        <section style="margin-bottom:56px;" id={sec.id}>
          <h1 style="font-size:clamp(26px,2.8vw,36px);font-weight:800;letter-spacing:-0.04em;color:#1d1d1f;margin:0 0 24px;line-height:1.36;">
            {sec.heading}
          </h1>
          {sec.body.map((para, i) => (
            <p style={`font-size:18px;line-height:1.75;color:#3d3d3f;font-weight:400;margin:${i === 0 ? '0 0 22px' : '0 0 12px'};`}>{para}</p>
          ))}

          {si === 0 && (
            <div style="background:#fff;border-radius:18px;padding:28px 32px;margin-top:24px;border:1px solid #e5e5ea;">
              <p style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.13em;color:#8e8e93;margin:0 0 6px;">How it works</p>
              <p style="font-size:20px;font-weight:800;color:#1d1d1f;margin:0 0 20px;line-height:1.2;letter-spacing:-0.02em;">Strategy first. Everything else follows.</p>
              {timelineSteps.map((step, idx) => (
                <div>
                  {idx > 0 && <div style="height:1px;background:#e5e5ea;"></div>}
                  <div style="display:flex;gap:14px;padding:13px 0;">
                    <div style="width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,#e8a0c8 0%,#c87aaa 100%);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;">
                      <span style="font-size:11px;font-weight:800;color:#fff;">{idx + 1}</span>
                    </div>
                    <div style="flex:1;">
                      <p style="font-size:14px;font-weight:700;color:#1d1d1f;margin:0 0 3px;line-height:1.2;">{step.label}</p>
                      <p style="font-size:13px;color:#6e6e73;margin:0;line-height:1.55;">{step.body}</p>
                    </div>
                  </div>
                </div>
              ))}
              <a href={p('/about')} style="display:inline-block;margin-top:12px;background:#1d1d1f;color:#fff;border-radius:980px;padding:12px 24px;font-size:14px;font-weight:600;text-decoration:none;font-family:var(--font-sf);">
                Start with a free call
              </a>
            </div>
          )}
        </section>
      ))}

    </main>

    <!-- Sidebar -->
    <aside class="editorial-sidebar">
      {sidebarCards.map(card => (
        <div style="background:#fff;border-radius:18px;padding:20px 18px 24px;margin-bottom:40px;border:1px solid #e5e5ea;position:relative;">
          <svg width="34" height="34" viewBox={card.vb} fill="none" stroke="#1d1d1f" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <Fragment set:html={card.icon} />
          </svg>
          <h4 style="font-size:20px;font-weight:700;color:#1d1d1f;margin:10px 0 10px;line-height:1.2;">{card.title}</h4>
          <p style="font-size:17px;color:#1d1d1f;margin:0 0 10px;line-height:1.55;">{card.description}</p>
          {card.items.map(item => (
            <p style="font-size:17px;color:#2997ff;margin:0 0 3px;line-height:26px;">{item}</p>
          ))}
        </div>
      ))}
      <a href={p('/about')} style="display:block;background:#1d1d1f;color:#fff;font-size:14px;font-weight:600;letter-spacing:-0.01em;padding:12px 24px;border-radius:40px;text-decoration:none;text-align:center;transition:opacity 0.15s;"
        onmouseenter="this.style.opacity='0.82'"
        onmouseleave="this.style.opacity='1'"
      >Free Consultation</a>
    </aside>

  </div>

</BaseLayout>

<style>
  .editorial-wrap {
    display: flex;
    flex-direction: column;
    gap: 32px;
    padding: 60px var(--side-pad) 80px;
    max-width: 1280px;
    margin: 0 auto;
    align-items: flex-start;
  }
  .editorial-sidebar {
    width: 100%;
    position: static;
  }
  @media (min-width: 840px) {
    .editorial-wrap {
      flex-direction: row;
      gap: 52px;
    }
    .editorial-sidebar {
      flex: 0 0 300px;
      width: 300px;
      position: sticky;
      top: 24px;
    }
  }
</style>
