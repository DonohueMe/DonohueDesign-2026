---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { p } from '../utils/path';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Website Design Santa Rosa",
  "description": "Strategy-first website design for Santa Rosa and Sonoma County businesses.",
  "provider": {
    "@type": "ProfessionalService",
    "name": "Donohue Design",
    "url": "https://donahuedesign.com",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Santa Rosa",
      "addressRegion": "CA",
      "addressCountry": "US"
    }
  },
  "areaServed": "Santa Rosa, CA",
  "serviceType": "Web Design"
};

const timelineSteps = [
  { label: 'Purpose & Goals',          body: 'Lead generation, e-commerce, brand awareness \u2014 with measurable KPIs tied to business objectives.' },
  { label: 'Target Audience',          body: 'User personas, journey mapping, pain points, and how real customers behave.' },
  { label: 'Content Strategy',         body: 'What to create, how to organize it, tone of voice, and messaging hierarchy.' },
  { label: 'Information Architecture', body: 'Site structure, navigation, and page hierarchy so users find what they need.' },
  { label: 'Technical Strategy',       body: 'Platform, hosting, performance, security, accessibility, and mobile-friendliness.' },
  { label: 'SEO & Discoverability',    body: 'Keyword targeting, on-page optimization, and visibility in search and AI-powered results.' },
  { label: 'Conversion Optimization',  body: 'CTAs, landing pages, and funnel design that turn visitors into customers.' },
  { label: 'Measurement & Iteration',  body: 'Analytics, A/B testing, and ongoing performance review cycles.' },
];

const sidebarCards = [
  {
    title: 'Website Design',
    description: 'Strategy-first websites built to generate leads, earn trust, and turn visitors into customers.',
    items: ['Website Design & Strategy', 'Smart Websites', 'Website Development'],
  },
  {
    title: 'Digital Marketing',
    description: 'AI-powered campaigns, local SEO, and automated outreach \u2014 running around the clock to grow your business.',
    items: ['Local SEO (Google My Business)', 'AI Receptionist', 'Email Marketing Automation'],
  },
  {
    title: 'Graphic Design',
    description: 'Logos, brand systems, and marketing materials that make your business look like the professional operation it already is.',
    items: ['Presentation Design', 'Email Design', 'Brochure & Flyer Design', 'Logo Design'],
  },
];

const bio = [
  'Most website designers jump straight into building. I start with strategy.',
  'Before I open a design tool, I want to know who your customers are, how they find you, and what you need them to do when they land on your site. That\u2019s the difference between a website that looks good and one that actually brings in business.',
  'My name is Jim Donohue. I\u2019m a website designer in Santa Rosa, CA with over 20 years of experience in design, UI/UX, and digital strategy. I spent years as a Senior Product Designer at companies like Wells Fargo and Deloitte \u2014 building products used across dozens of applications and leading redesigns that drove measurable results.',
];

const designStrategyBody = [
  'Good design starts with a question: what do you need this website to do? Not how should it look \u2014 what should it accomplish.',
  'Every page, every call-to-action, and every navigation path is a decision. I map those decisions to your business goals before a single pixel gets placed. The result is a site that isn\u2019t just attractive \u2014 it\u2019s built to convert.',
  'From information architecture and content hierarchy to mobile performance and SEO structure, strategy is woven into every layer of the build.',
];

const smartWebBody = [
  'A smart website knows who it\u2019s talking to. It loads fast, ranks in search, guides visitors to the right action, and tells you exactly what\u2019s working.',
  'That means clean code, optimized images, proper heading structure, schema markup for Google, and analytics wired up from day one \u2014 not bolted on as an afterthought.',
];

const devBody = [
  'I build on modern stacks \u2014 Astro, Next.js, or whatever technology best fits your goals \u2014 with Tailwind CSS for precise, responsive design and Alpine.js for lightweight interactivity.',
  'No bloated page builders. No mystery plugins. Clean, maintainable code you can hand off to any developer.',
];
---

<BaseLayout
  title="Website Designer Santa Rosa | Donohue Design"
  description="Strategy-first website design for Santa Rosa and Sonoma County businesses. Jim Donohue \u2014 20+ years in UX/UI and digital strategy."
  schema={schema}
>

  <Hero />

  <!-- ═══ BODY: editorial + sidebar ═══ -->
  <div style="display:flex;flex-wrap:wrap;gap:52px;padding:60px var(--side-pad) 80px;max-width:1280px;margin:0 auto;align-items:flex-start;">

    <!-- Main editorial -->
    <main style="flex:1 1 0;min-width:0;">

      <section style="margin-bottom:56px;">
        <h1 style="font-size:clamp(26px,2.8vw,36px);font-weight:800;letter-spacing:-0.04em;color:var(--clr-text);margin:0 0 24px;line-height:1.36;">
          Website Designer Santa Rosa
        </h1>
        {bio.map((para, i) => (
          <p style={`font-size:18px;line-height:1.75;color:var(--clr-sub);font-weight:400;margin:${i === 0 ? '0 0 22px' : '0 0 12px'};`}>{para}</p>
        ))}
      </section>

      <section style="margin-bottom:56px;" id="strategy">
        <h2 style="font-size:clamp(26px,2.8vw,36px);font-weight:800;letter-spacing:-0.04em;color:var(--clr-text);margin:0 0 24px;line-height:1.36;">
          Website Design and Strategy
        </h2>
        {designStrategyBody.map((para, i) => (
          <p style={`font-size:18px;line-height:1.75;color:var(--clr-sub);font-weight:400;margin:${i === 0 ? '0 0 22px' : '0 0 12px'};`}>{para}</p>
        ))}
        <div style="margin-top:36px;display:flex;flex-direction:column;gap:0;">
          {timelineSteps.map((step, si) => (
            <div style={`display:flex;gap:20px;padding:18px 0;${si < timelineSteps.length - 1 ? 'border-bottom:1px solid var(--clr-border)' : ''};`}>
              <div style="flex-shrink:0;width:28px;height:28px;border-radius:50%;background:#110621;color:#fff;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;margin-top:2px;">
                {si + 1}
              </div>
              <div>
                <p style="font-size:16px;font-weight:700;color:var(--clr-text);margin:0 0 4px;letter-spacing:-0.02em;">{step.label}</p>
                <p style="font-size:15px;line-height:1.6;color:var(--clr-sub);margin:0;">{step.body}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section style="margin-bottom:56px;" id="ux">
        <h2 style="font-size:clamp(26px,2.8vw,36px);font-weight:800;letter-spacing:-0.04em;color:var(--clr-text);margin:0 0 24px;line-height:1.36;">
          Smart Websites
        </h2>
        {smartWebBody.map((para, i) => (
          <p style={`font-size:18px;line-height:1.75;color:var(--clr-sub);font-weight:400;margin:${i === 0 ? '0 0 22px' : '0 0 12px'};`}>{para}</p>
        ))}
      </section>

      <section style="margin-bottom:56px;" id="dev">
        <h2 style="font-size:clamp(26px,2.8vw,36px);font-weight:800;letter-spacing:-0.04em;color:var(--clr-text);margin:0 0 24px;line-height:1.36;">
          Website Development
        </h2>
        {devBody.map((para, i) => (
          <p style={`font-size:18px;line-height:1.75;color:var(--clr-sub);font-weight:400;margin:${i === 0 ? '0 0 22px' : '0 0 12px'};`}>{para}</p>
        ))}
      </section>

    </main>

    <!-- Sidebar -->
    <aside style="flex:0 0 300px;position:sticky;top:104px;display:flex;flex-direction:column;gap:0;">
      {sidebarCards.map(card => (
        <div style="background:#fff;border-radius:18px;padding:20px 18px 24px;margin-bottom:32px;border:1px solid var(--clr-border);">
          <p style="font-size:20px;font-weight:700;color:var(--clr-text);margin:12px 0 10px;line-height:1.2;">{card.title}</p>
          <p style="font-size:17px;color:var(--clr-text);margin:0 0 12px;line-height:1.55;">{card.description}</p>
          {card.items.map(item => (
            <p style="font-size:17px;color:var(--clr-link);margin:0 0 3px;line-height:26px;">{item}</p>
          ))}
        </div>
      ))}
      <a href={p('/about')} style="display:block;background:#110621;color:#fff;font-size:16px;font-weight:600;letter-spacing:-0.01em;padding:14px 24px;border-radius:40px;text-decoration:none;text-align:center;transition:opacity 0.15s;"
        onmouseenter="this.style.opacity='0.82'"
        onmouseleave="this.style.opacity='1'"
      >Free Consultation</a>
    </aside>

  </div>

</BaseLayout>
