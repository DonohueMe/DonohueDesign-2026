---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { p } from '../utils/path';

const schema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Donohue Design",
  "description": "Strategy-first website design and digital marketing for Santa Rosa businesses.",
  "url": "https://donahuedesign.com",
  "founder": { "@type": "Person", "name": "Jim Donohue" },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Santa Rosa",
    "addressRegion": "CA",
    "addressCountry": "US"
  },
  "areaServed": ["Santa Rosa", "Sonoma County", "Marin County", "Napa County"],
  "serviceType": ["Web Design", "Digital Marketing", "Graphic Design"]
};

const tiles = [
  {
    eyebrow: 'Website Designer Santa Rosa',
    h3: 'Your website. Working harder than ever.',
    body: 'A well-designed website isn\'t just attractive — it\'s strategic. Every layout choice, call-to-action, and navigation path should guide visitors toward a clear goal. In 2025, that means mobile-first design, fast load times, and content built around what your customers actually need.',
    links: [
      { label: 'Website Design & Strategy', href: p('/website-designer-santa-rosa') },
      { label: 'Smart Websites',            href: p('/website-designer-santa-rosa#ux') },
      { label: 'Website Development',       href: p('/website-designer-santa-rosa#dev') },
    ],
    reverse: false,
  },
  {
    eyebrow: 'Digital Marketing Santa Rosa',
    h3: 'Get found. Stay top of mind.',
    body: 'Email campaigns and local SEO that put your business in front of the right people at the right time. AI-powered tools running around the clock so you never miss a lead.',
    links: [
      { label: 'Local SEO (Google My Business)', href: p('/digital-marketing-santa-rosa') },
      { label: 'AI Receptionist',                href: p('/digital-marketing-santa-rosa#ai') },
      { label: 'Email Marketing Automation',     href: p('/digital-marketing-santa-rosa#email') },
    ],
    reverse: true,
  },
  {
    eyebrow: 'Graphic Designer Santa Rosa',
    h3: 'A brand as strong as your business.',
    body: 'Everything matches your website — same colors, same feel, same level of quality across every touchpoint. From logos to pitch decks to print.',
    links: [
      { label: 'Presentation Design',     href: p('/graphic-designer-santa-rosa#slides') },
      { label: 'Email Design',            href: p('/graphic-designer-santa-rosa#email') },
      { label: 'Brochure & Flyer Design', href: p('/graphic-designer-santa-rosa#print') },
      { label: 'Logo Design',             href: p('/graphic-designer-santa-rosa') },
    ],
    reverse: false,
  },
];

const sideCards = [
  {
    bg: '#fff8ec', accent: '#d18a16',
    eyebrow: 'Local SEO · GBP',
    title: 'Own the map. Own the moment.',
    body: 'Rank higher on Google Maps and capture every nearby search.',
    iconPath: 'M12 22s7-7 7-12a7 7 0 1 0-14 0c0 5 7 12 7 12z',
    iconExtra: '<circle cx="12" cy="10" r="2.5"/>',
  },
  {
    bg: '#f0fbf6', accent: '#1f9d6a',
    eyebrow: 'AI Receptionist',
    title: 'Never miss a call again.',
    body: 'A 24/7 voice that books, qualifies, and confirms — in a single ring.',
    iconPath: 'M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z',
    iconExtra: '',
  },
  {
    bg: '#eef6ff', accent: '#1f6fd6',
    eyebrow: 'Smart Websites',
    title: 'Sites that earn their keep.',
    body: 'Strategy-first design built to turn quiet visitors into paying customers.',
    iconPath: 'M8 6 3 12 8 18M16 6l5 6-5 6',
    iconExtra: '',
  },
  {
    bg: '#fdf1f6', accent: '#c43c75',
    eyebrow: 'Presentation Design',
    title: 'Decks that win the room.',
    body: 'Investor-ready slides built around the story you are telling.',
    iconPath: 'M3 4h18a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2zM8 21l4-4 4 4M7 9h6M7 12h10',
    iconExtra: '',
  },
];

const reviews = [
  { name: 'Maria T.', location: 'Santa Rosa, CA', text: 'Jim redesigned our winery site and bookings went up 30% in the first month. He actually understood what we needed before we did.' },
  { name: 'Derek H.', location: 'Petaluma, CA',   text: 'We went from page 3 to page 1 on Google for our main keyword. The SEO strategy Jim put together was exactly what our shop needed.' },
  { name: 'Lisa M.', location: 'Healdsburg, CA',  text: 'The AI receptionist handles after-hours calls now. We haven\'t missed a lead in weeks. Worth every penny.' },
];
---

<BaseLayout
  title="Website Designer Santa Rosa | Donohue Design"
  description="Strategy-first website design and digital marketing for Santa Rosa businesses. Jim Donohue — 20+ years in UI/UX, formerly Wells Fargo and Deloitte."
  schema={schema}
>

  <Hero variant="home" />

  <!-- ═══ Bio intro ═══ -->
  <section style="padding:16px 0;background:#fff;">
    <div style="max-width:1280px;margin:0 auto;text-align:center;padding:0 var(--side-pad);">
      <h1 style="font-size:clamp(26px,2.8vw,36px);font-weight:800;letter-spacing:-0.04em;line-height:1.36;color:#1d1d1f;margin:44px 0 24px;">
        Website Designer Santa Rosa
      </h1>
      <p style="font-size:18px;color:#3d3d3f;line-height:1.65;margin:0 0 14px;">
        Most website designers jump straight into building. I start with strategy. Before I open a design tool, I want to know who your customers are and what you need them to do.
      </p>
      <p style="font-size:18px;color:#3d3d3f;line-height:1.65;margin:0 0 44px;">
        Jim Donohue. 20+ years. Senior Product Designer at Wells Fargo and Deloitte. 15% lift in subscriptions. 22% jump in engagement. Design systems used across 90+ apps.
      </p>
    </div>
  </section>

  <!-- ═══ Service tiles + sidebar ═══ -->
  <div style="background:#fff;padding:60px 0;">
    <div class="tiles-outer" style="max-width:1280px;margin:0 auto;padding:0 var(--side-pad);">

      <!-- Left: tiles -->
      <div style="display:flex;flex-direction:column;gap:48px;min-width:0;">
        {tiles.map((tile) => (
          <div style="background:#fff;border-radius:20px;padding:44px 56px;box-shadow:0 12px 40px rgba(0,0,0,0.08),0 2px 6px rgba(0,0,0,0.04);">
            <div class={tile.reverse ? 'tile-inner tile-reverse' : 'tile-inner'}>
              <div class="tile-text">
                <h2 style="font-size:17px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:#2997ff;margin:0 0 14px;line-height:25px;">{tile.eyebrow}</h2>
                <h3 style="font-size:30px;font-weight:700;letter-spacing:-0.03em;line-height:1.23;color:#1d1d1f;margin:0 0 20px;">{tile.h3}</h3>
                <p style="font-size:18px;color:#1d1d1f;line-height:1.55;margin:0;">{tile.body}</p>
              </div>
              <div class="tile-links">
                {tile.links.map((lnk, li) => (
                  <div style={`border-bottom:1px solid #e5e5ea;padding:14px 0;display:flex;justify-content:space-between;align-items:center;${li === 0 ? 'border-top:1px solid #e5e5ea;' : ''}`}>
                    <a href={lnk.href} style="font-size:18px;color:#2997ff;text-decoration:none;"
                      onmouseenter="this.style.opacity='0.65'"
                      onmouseleave="this.style.opacity='1'"
                    >{lnk.label}</a>
                    <span style="color:#2997ff;font-size:22px;line-height:1;">›</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Right: sidebar cards -->
      <aside style="display:flex;flex-direction:column;gap:36px;min-width:0;">
        {sideCards.map((card) => (
          <div style={`background:${card.bg};border-radius:18px;padding:26px 24px;border:1px solid rgba(0,0,0,0.05);`}>
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
              <span style={`width:34px;height:34px;border-radius:10px;background:#fff;color:${card.accent};display:inline-flex;align-items:center;justify-content:center;box-shadow:0 1px 0 ${card.accent}25,inset 0 0 0 1px ${card.accent}25;flex-shrink:0;`}>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={card.iconPath} />
                  {card.iconExtra && <Fragment set:html={card.iconExtra} />}
                </svg>
              </span>
              <span style={`font-size:14px;font-weight:700;text-transform:uppercase;letter-spacing:0.16em;color:${card.accent};`}>{card.eyebrow}</span>
            </div>
            <h4 style="font-size:22px;font-weight:700;letter-spacing:-0.03em;line-height:1.15;margin:0 0 12px;color:#1d1d1f;">{card.title}</h4>
            <p style="font-size:17px;line-height:25px;color:#1d1d1f;margin:0;">{card.body}</p>
          </div>
        ))}
      </aside>

    </div>
  </div>

  <!-- ═══ Reviews ═══ -->
  <div style="background:#fff;padding:20px 0 60px;">
    <div style="max-width:1280px;margin:0 auto;padding:0 var(--side-pad);">
      <div style="padding:32px 0 48px;">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:32px;">
          <p style="font-size:17px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:#2997ff;margin:0;">Client Reviews</p>
          <div style="display:flex;gap:2px;">{[1,2,3,4,5].map(() => <span style="color:#FFB800;font-size:14px;">★</span>)}</div>
          <span style="font-size:13px;color:#6e6e73;">5.0 · Google</span>
        </div>
        <div class="reviews-grid">
          {reviews.map((r) => (
            <div>
              <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
                <div style="width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,#e0e7ff,#c7d2fe);display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:700;color:#4338ca;flex-shrink:0;">{r.name[0]}</div>
                <div>
                  <p style="font-size:14px;font-weight:700;color:#1d1d1f;margin:0;line-height:1.2;">{r.name}</p>
                  <p style="font-size:12px;color:#8e8e93;margin:0;">{r.location}</p>
                </div>
                <div style="margin-left:auto;display:flex;gap:1px;">{[1,2,3,4,5].map(() => <span style="color:#FFB800;font-size:12px;">★</span>)}</div>
              </div>
              <p style="font-size:15px;color:#3d3d3f;line-height:1.6;margin:0;">{r.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

</BaseLayout>

<style>
  .tiles-outer {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }
  @media (min-width: 840px) {
    .tiles-outer {
      grid-template-columns: 1fr 300px;
      gap: 74px;
    }
  }

  /* Tile internal layout — stacked by default, side-by-side at xl */
  .tile-inner {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .tile-links {
    border-top: 1px solid #e5e5ea;
    padding-top: 8px;
  }
  @media (min-width: 1280px) {
    .tile-inner {
      flex-direction: row;
      align-items: center;
      gap: 56px;
    }
    .tile-reverse {
      flex-direction: row-reverse;
    }
    .tile-text {
      flex: 3;
      min-width: 0;
    }
    .tile-links {
      flex: 2;
      min-width: 0;
      border-top: none;
      border-left: 1px solid #e5e5ea;
      padding-top: 0;
      padding-left: 40px;
    }
    .tile-reverse .tile-links {
      border-left: none;
      border-right: 1px solid #e5e5ea;
      padding-left: 0;
      padding-right: 40px;
    }
  }

  /* Tile padding responsive */
  @media (max-width: 839px) {
    .tiles-outer > div > div {
      padding: 28px 24px !important;
    }
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }
  @media (min-width: 640px) {
    .reviews-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (min-width: 1024px) {
    .reviews-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }
</style>
