---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { p } from '../utils/path';

const schema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Donohue Design",
  "description": "Strategy-first website design and digital marketing for Santa Rosa businesses.",
  "url": "https://donahuedesign.com",
  "founder": { "@type": "Person", "name": "Jim Donohue" },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Santa Rosa",
    "addressRegion": "CA",
    "addressCountry": "US"
  },
  "areaServed": ["Santa Rosa", "Sonoma County", "Marin County", "Napa County"],
  "serviceType": ["Web Design", "Digital Marketing", "Graphic Design"]
};

const tiles = [
  {
    eyebrow: 'Website Design',
    h1: 'Website Designer Santa Rosa',
    href: p('/website-designer-santa-rosa'),
    body: 'I build websites that work — not just look good. Every layout, call-to-action, and navigation path is mapped to your business goals before a pixel gets placed.',
    links: [
      { label: 'Website Design & Strategy', href: p('/website-designer-santa-rosa') },
      { label: 'UX / UI Design',            href: p('/website-designer-santa-rosa#ux') },
      { label: 'Website Development',        href: p('/website-designer-santa-rosa#dev') },
    ],
  },
  {
    eyebrow: 'Digital Marketing',
    h1: 'Digital Marketing Santa Rosa',
    href: p('/digital-marketing-santa-rosa'),
    body: 'AI-powered campaigns, local SEO, and automated outreach that run around the clock — so your business keeps growing even when you\'re not at your desk.',
    links: [
      { label: 'Local SEO (Google My Business)', href: p('/digital-marketing-santa-rosa') },
      { label: 'Email Marketing Automation',      href: p('/digital-marketing-santa-rosa#email') },
      { label: 'AI Receptionist',                 href: p('/digital-marketing-santa-rosa#ai') },
    ],
  },
  {
    eyebrow: 'Graphic Design',
    h1: 'Graphic Designer Santa Rosa',
    href: p('/graphic-designer-santa-rosa'),
    body: 'Logos, brand systems, and marketing materials that make your business look like the professional operation it already is.',
    links: [
      { label: 'Logo Design',             href: p('/graphic-designer-santa-rosa') },
      { label: 'Brochure & Flyer Design', href: p('/graphic-designer-santa-rosa#print') },
      { label: 'Presentation Design',     href: p('/graphic-designer-santa-rosa#slides') },
      { label: 'Email Design',            href: p('/graphic-designer-santa-rosa#email') },
    ],
  },
];

const bio = [
  'Most website designers jump straight into building. I start with strategy.',
  'Before I open a design tool, I want to know who your customers are, how they find you, and what you need them to do when they land on your site. That\u2019s the difference between a website that looks good and one that actually brings in business.',
  'My name is Jim Donohue. I\u2019m a website designer in Santa Rosa, CA with over 20 years of experience in design, UI/UX, and digital strategy. I spent years as a Senior Product Designer at companies like Wells Fargo and Deloitte \u2014 leading redesigns that drove a 15% lift in subscriptions, a 22% jump in user engagement, and design systems adopted across 90+ applications.',
];
---

<BaseLayout
  title="Website Designer Santa Rosa | Donohue Design"
  description="Strategy-first website design and digital marketing for Santa Rosa businesses. Jim Donohue — 20+ years in UI/UX, formerly Wells Fargo and Deloitte."
  schema={schema}
>

  <Hero />

  <!-- ═══ BODY: bio intro + service tiles ═══ -->
  <div style="padding:60px var(--side-pad) 80px;max-width:1280px;margin:0 auto;">

    <!-- Bio intro -->
    <div style="max-width:760px;margin-bottom:64px;">
      <h1 style="font-size:clamp(26px,2.8vw,36px);font-weight:800;letter-spacing:-0.04em;color:var(--clr-text);margin:0 0 24px;line-height:1.36;">
        Website Designer Santa Rosa
      </h1>
      {bio.map((para, i) => (
        <p style={`font-size:18px;line-height:1.75;color:var(--clr-sub);font-weight:400;margin:${i === 0 ? '0 0 22px' : '0 0 14px'};`}>{para}</p>
      ))}
    </div>

    <!-- Service tiles -->
    <div style="display:flex;flex-direction:column;gap:0;">
      {tiles.map((tile, ti) => (
        <article style={`padding:36px 0;${ti < tiles.length - 1 ? 'border-bottom:1px solid var(--clr-border)' : ''};`}>
          <div style="display:flex;flex-wrap:wrap;gap:32px;align-items:flex-start;">

            <!-- Left: text (60%) -->
            <div style="flex:6 1 280px;min-width:0;">
              <p style="font-size:13px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--clr-meta);margin:0 0 14px;">{tile.eyebrow}</p>
              <h2 style="font-size:clamp(22px,2.4vw,30px);font-weight:800;letter-spacing:-0.035em;color:var(--clr-text);margin:0 0 14px;line-height:1.3;">
                <a href={tile.href} style="text-decoration:none;color:inherit;">{tile.h1}</a>
              </h2>
              <p style="font-size:17px;line-height:1.7;color:var(--clr-sub);margin:0;">{tile.body}</p>
            </div>

            <!-- Right: links (40%) -->
            <div style="flex:4 1 180px;min-width:0;padding-top:38px;">
              {tile.links.map((lnk, li) => (
                <a
                  href={lnk.href}
                  style={`font-size:17px;color:var(--clr-link);text-decoration:none;display:block;padding:8px 0;font-weight:500;letter-spacing:-0.01em;${li < tile.links.length - 1 ? 'border-bottom:1px solid var(--clr-border)' : ''};`}
                  onmouseenter="this.style.opacity='0.65'"
                  onmouseleave="this.style.opacity='1'"
                >{lnk.label}</a>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>

  <!-- ═══ CTA BAND ═══ -->
  <section style="background:var(--clr-surf);padding:64px var(--side-pad);text-align:center;">
    <p style="font-size:clamp(22px,2.5vw,32px);font-weight:800;letter-spacing:-0.035em;color:var(--clr-text);margin:0 0 12px;">
      Ready to grow your business?
    </p>
    <p style="font-size:18px;color:var(--clr-sub);margin:0 0 28px;">
      Let's talk strategy. No hard sell, no obligation.
    </p>
    <a href={p('/about')} style="display:inline-block;background:#110621;color:#fff;font-size:16px;font-weight:600;letter-spacing:-0.01em;padding:14px 32px;border-radius:40px;text-decoration:none;transition:opacity 0.15s;"
      onmouseenter="this.style.opacity='0.82'"
      onmouseleave="this.style.opacity='1'"
    >Schedule a Free Consultation</a>
  </section>

</BaseLayout>
