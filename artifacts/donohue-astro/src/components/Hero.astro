---
interface Props {
  variant?: 'home' | 'web' | 'marketing';
}
const { variant = 'web' } = Astro.props;
import { p } from '../utils/path';

type HeroCfg = {
  bg: string;
  text: [string, string];
  textColor: string;
  ctaBg: string;
  ctaColor: string;
  hrColor: string;
  subColor: string;
  waves: boolean;
  padding: string;
};

const configs: Record<string, HeroCfg> = {
  home: {
    bg: [
      'radial-gradient(ellipse at 12% 20%, rgba(90,170,255,0.90) 0%, transparent 45%)',
      'radial-gradient(ellipse at 85% 15%, rgba(70,220,195,0.85) 0%, transparent 45%)',
      'radial-gradient(ellipse at 50% 62%, rgba(100,195,250,0.70) 0%, transparent 50%)',
      'radial-gradient(ellipse at 80% 85%, rgba(80,240,190,0.80) 0%, transparent 40%)',
      '#dff3ff',
    ].join(','),
    text: ['Beautiful websites.', 'Powered by smart marketing.'],
    textColor: '#000',
    ctaBg: '#000',
    ctaColor: '#fff',
    hrColor: 'rgba(0,0,0,0.18)',
    subColor: '#3d3d3f',
    waves: false,
    padding: '80px 0 80px',
  },
  web: {
    bg: 'radial-gradient(ellipse 70% 60% at 50% 18%, #4a2670 0%, #2c1548 35%, #1a0a30 70%, #110621 100%)',
    text: ['Built on strategy.', 'Powered by AI.'],
    textColor: '#fff',
    ctaBg: '#fff',
    ctaColor: '#1a0a30',
    hrColor: 'rgba(255,255,255,0.9)',
    subColor: 'rgba(255,255,255,0.70)',
    waves: true,
    padding: '80px 40px 100px',
  },
  marketing: {
    bg: [
      'radial-gradient(ellipse at 15% 30%, rgba(196,153,226,0.90) 0%, transparent 50%)',
      'radial-gradient(ellipse at 85% 15%, rgba(255,185,120,0.85) 0%, transparent 50%)',
      'radial-gradient(ellipse at 60% 70%, rgba(248,220,130,0.70) 0%, transparent 50%)',
      '#f0eaf8',
    ].join(','),
    text: ['Strategy first.', 'Results always.'],
    textColor: '#1d1d1f',
    ctaBg: '#000',
    ctaColor: '#fff',
    hrColor: 'rgba(0,0,0,0.15)',
    subColor: '#3d3d3f',
    waves: false,
    padding: '80px 40px 80px',
  },
};

const cfg = configs[variant];
---

<section style={`position:relative;overflow:hidden;background:${cfg.bg};display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:${cfg.padding};`}>

  {cfg.waves && (
    <svg aria-hidden="true" viewBox="0 0 1440 400" preserveAspectRatio="none"
      style="position:absolute;left:0;right:0;bottom:0;width:100%;height:45%;pointer-events:none;">
      <path d="M0,120 C260,-20 520,300 820,140 C1120,-20 1300,260 1440,120 L1440,400 L0,400 Z" fill="#3a1f5c" opacity="0.85"/>
      <path d="M0,200 C200,-40 520,400 800,180 C1080,-40 1280,380 1440,170 L1440,400 L0,400 Z" fill="#6b3aa0"/>
      <path d="M0,260 C280,120 600,400 920,220 C1180,80 1320,360 1440,240 L1440,400 L0,400 Z" fill="#26123e"/>
    </svg>
  )}

  <div style="position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;max-width:860px;padding:0 20px;">
    <p style={`font-size:clamp(36px,7vw,80px);font-weight:700;line-height:1.25;letter-spacing:-0.04em;color:${cfg.textColor};margin:0 0 18px;`}>
      {cfg.text[0]}<br />{cfg.text[1]}
    </p>
    <hr style={`border:none;border-top:1px solid ${cfg.hrColor};width:100px;margin:40px 0 24px;`} />
    <p style={`font-size:18px;color:${cfg.subColor};font-weight:500;margin:0 0 20px;letter-spacing:-0.01em;`}>
      Schedule your free consultation now.
    </p>
    <a href={p('/about')} style={`display:inline-block;background:${cfg.ctaBg};color:${cfg.ctaColor};font-size:16px;font-weight:600;letter-spacing:-0.01em;padding:14px 32px;border-radius:40px;text-decoration:none;transition:opacity 0.15s;`}
      onmouseenter="this.style.opacity='0.82'"
      onmouseleave="this.style.opacity='1'"
    >Get Started</a>
  </div>
</section>
