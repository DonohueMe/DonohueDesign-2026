---
import { p } from '../utils/path';

const footerLinks = [
  { label: 'Website Designer',  href: p('/website-designer-santa-rosa') },
  { label: 'Digital Marketing', href: p('/digital-marketing-santa-rosa') },
  { label: 'Graphic Designer',  href: p('/graphic-designer-santa-rosa') },
  { label: 'Case Studies',      href: p('/case-studies') },
  { label: 'Pricing',           href: p('/pricing') },
  { label: 'About / Contact',   href: p('/about') },
];
---

<footer style="background:#000;padding:48px var(--side-pad);color:#fff;font-family:var(--font-sf);">
  <div style="max-width:1280px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:auto 1fr;gap:75px;padding-bottom:28px;align-items:start;" class="max-md:grid-cols-1 max-md:gap-6">

      <div>
        <p style="font-size:22px;font-weight:700;color:#fff;margin:0 0 6px;letter-spacing:-0.01em;">Donohue Design</p>
        <p style="font-size:14px;color:rgba(255,255,255,0.78);font-weight:500;margin:0 0 4px;">Santa Rosa, CA</p>
        <p style="font-size:14px;color:rgba(255,255,255,0.78);font-weight:500;margin:0 0 20px;">Serving Sonoma, Marin &amp; Napa Counties</p>

        <div style="display:flex;gap:12px;margin-bottom:20px;">
          <a href="https://linkedin.com" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer"
            style="width:48px;height:48px;border-radius:50%;background:#363636;display:flex;align-items:center;justify-content:center;text-decoration:none;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="white">
              <path d="M20.5 2h-17A1.5 1.5 0 0 0 2 3.5v17A1.5 1.5 0 0 0 3.5 22h17a1.5 1.5 0 0 0 1.5-1.5v-17A1.5 1.5 0 0 0 20.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 1 1 8.25 6.5 1.75 1.75 0 0 1 6.5 8.25zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93a1.74 1.74 0 0 0-1.62 1.83V19h-3v-9h2.9v1.3a3.11 3.11 0 0 1 2.7-1.4c1.55 0 3.36.86 3.36 3.66z"/>
            </svg>
          </a>
          <a href="https://facebook.com" aria-label="Facebook" target="_blank" rel="noopener noreferrer"
            style="width:48px;height:48px;border-radius:50%;background:#363636;display:flex;align-items:center;justify-content:center;text-decoration:none;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="white">
              <path d="M22 12a10 10 0 1 0-11.6 9.9V15h-2.5v-3h2.5V9.8c0-2.5 1.5-3.9 3.7-3.9 1.1 0 2.2.2 2.2.2v2.5H15c-1.2 0-1.6.8-1.6 1.6V12h2.8l-.5 3h-2.4v6.9A10 10 0 0 0 22 12z"/>
            </svg>
          </a>
        </div>

        <p style="font-size:14px;color:rgba(255,255,255,0.55);margin:0;">&copy;2026 Donohue Design</p>
      </div>

      <nav style="display:flex;flex-wrap:wrap;column-gap:32px;row-gap:14px;align-self:flex-start;padding-top:4px;">
        {footerLinks.map(link => (
          <a href={link.href} style="font-size:14px;color:rgba(255,255,255,0.78);text-decoration:none;font-weight:500;white-space:nowrap;"
            onmouseenter="this.style.color='#fff'"
            onmouseleave="this.style.color='rgba(255,255,255,0.78)'"
          >{link.label}</a>
        ))}
      </nav>
    </div>
  </div>
</footer>
